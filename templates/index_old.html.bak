<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Liquidation Contrarian Agent</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#09090f;color:#d0d0d0;font-family:system-ui,'Segoe UI',sans-serif;min-height:100vh}
.liq-page{background:#f6f6f6;color:#111;border:1px solid #ddd;border-radius:6px;padding:0;margin-bottom:16px}.liq-title{font-size:18px;font-weight:800;padding:18px 18px 30px}.liq-card{background:#fff;border:1px solid #ddd;border-radius:5px;overflow:hidden;margin:0 0 6px}.liq-toolbar{height:52px;display:flex;align-items:center;gap:12px;padding:0 10px;border-bottom:1px solid #e5e5e5}.liq-toolbar select{height:32px;background:#eef1f5;border:none;border-radius:6px;padding:0 28px 0 8px;color:#233;font-size:13px}.liq-check{display:flex;align-items:center;gap:6px;font-size:13px;color:#111}.liq-check input{width:20px;height:20px;accent-color:#0b73df}.liq-slider{display:flex;align-items:center;gap:8px;font-size:13px;color:#111}.liq-slider input{width:120px;accent-color:#0b73df}.liq-chart{height:720px;width:100%}
.hdr{background:#111122;padding:14px 24px;display:flex;align-items:center;gap:10px;border-bottom:2px solid #222;position:sticky;top:0;z-index:10}
.hdr h1{font-size:17px;font-weight:700;color:#fff}.hdr span.badge{font-size:10px;background:#112211;color:#0c6;padding:3px 10px;border-radius:10px}
.ctn{max-width:1500px;margin:0 auto;padding:16px}.cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px}
.card,.panel,.st{background:#14141e;border-radius:10px;padding:16px;border:1px solid #2a2a3a}.card h3,.panel h4{font-size:11px;color:#888;margin-bottom:12px;text-transform:uppercase;letter-spacing:2px}
.inp{margin-bottom:10px}.inp label{display:block;font-size:10px;color:#777;margin-bottom:3px}.inp input,.inp select{width:100%;padding:8px 10px;background:#0a0a14;border:1px solid #2a2a3a;border-radius:6px;color:#ccc;font-size:12px;outline:none}.inp input:focus,.inp select:focus{border-color:#63f}
.btn{display:inline-flex;align-items:center;gap:5px;padding:8px 16px;border-radius:6px;font-size:12px;font-weight:600;border:none;cursor:pointer}.btn.primary{background:#6366f1;color:#fff}.btn.green{background:#00c47a;color:#000}.btn.red{background:#e44;color:#fff}.btn.outline{background:transparent;border:1px solid #333;color:#999}.btn.sm{padding:5px 10px;font-size:10px}.btn:hover{filter:brightness(1.2)}
.row{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}.addr{font-family:monospace;font-size:11px;color:#0c6;margin-top:8px;padding:6px 10px;background:#0a1a1a;border-radius:5px;display:none}.addr.on{display:block}.err{background:#1a1111;border:1px solid #322;border-radius:5px;padding:10px;margin-top:8px;color:#e66;font-size:11px;display:none}.err.on{display:block}
.providers{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;max-height:240px;overflow-y:auto}.prov{display:flex;align-items:center;gap:7px;padding:8px 10px;background:#0a0a14;border:1px solid #2a2a3a;border-radius:6px;cursor:pointer;font-size:10px;transition:.15s}.prov:hover,.prov.sel{border-color:#63f}.prov.sel{background:#1a1a2e}.prov .logo{width:22px;height:22px;border-radius:6px;object-fit:cover;background:#222;flex-shrink:0}.prov .fallback{width:22px;height:22px;border-radius:6px;display:none;align-items:center;justify-content:center;color:#fff;font-size:9px;font-weight:800}.prov .nm{font-weight:600;color:#ccc}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}.st{text-align:center}.st .v{font-size:20px;font-weight:800;font-family:monospace}.st .l{font-size:9px;color:#888;margin-top:2px}.st.red .v{color:#e44}.st.green .v{color:#0c6}.st.amber .v{color:#e90}.st.purple .v{color:#63f}
.agent-grid{display:grid;grid-template-columns:1.2fr .9fr .9fr;gap:14px;margin-bottom:16px}.cfg{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.kv{display:grid;grid-template-columns:120px 1fr;gap:8px;font-size:12px;margin:6px 0}.kv span:first-child{color:#777}.ok{color:#0c6}.bad{color:#e66}.warn{color:#e90}
.charts{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:16px}.panel.full{grid-column:1/-1}.echart{width:100%;height:300px}.echart.xl{height:400px}.table{width:100%;border-collapse:collapse;font-size:11px}.table th,.table td{border-bottom:1px solid #252535;padding:7px;text-align:left}.table th{color:#777}.raw{background:#0a0a14;border-radius:6px;padding:10px;max-height:400px;overflow:auto;font-size:10px;font-family:monospace;border:1px solid#1a1a2a;color:#888;display:none;white-space:pre-wrap}.raw.on{display:block}.hint{font-size:9px;color:#555;margin-top:6px}
.toast{position:fixed;top:16px;right:16px;padding:10px 18px;border-radius:6px;font-size:12px;z-index:99}.toast.err{background:#311;border:1px solid#522;color:#e44}.toast.ok{background:#131;border:1px solid#242;color:#0c6}.mask{position:fixed;inset:0;background:rgba(0,0,0,.6);display:none;align-items:center;justify-content:center;z-index:98}.mask.on{display:flex}.spinner{width:40px;height:40px;border:3px solid #222;border-top-color:#63f;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:4px}.dot.gry{background:#666}.dot.ylw{background:#e90;animation:pulse 1s infinite}.dot.grn{background:#0c6}.dot.red{background:#e44}@keyframes pulse{50%{opacity:.3}}
@media(max-width:1100px){.cards,.agent-grid,.charts{grid-template-columns:1fr}.cfg,.stats{grid-template-columns:repeat(2,1fr)}.providers{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<div class="hdr"><h1>Liquidation Contrarian Agent</h1><span class="badge">claw402</span><span class="badge">Contrarian Auto Strategy</span><div id="status" style="margin-left:auto;font-size:10px;color:#888"><span class="dot gry"></span>Stopped</div></div>
<div class="ctn">
  <div class="cards">
    <div class="card"><h3>1. Wallet (Base Data)</h3><div class="inp"><label>Private Key</label><input type="password" id="pk" placeholder="0x..."></div><div class="row"><button class="btn primary sm" onclick="connect()">Connect</button></div><div id="addr" class="addr"></div><div id="werr" class="err"></div></div>
    <div class="card"><h3>2. LLM Provider ({{ providers|length }})</h3><div class="providers" id="providers"></div><div class="inp" style="margin-top:8px"><label>LLM API Key</label><input type="password" id="llmKey" placeholder="sk-..."></div><div class="inp"><label>Model</label><select id="llmModel"></select></div><div class="row"><button class="btn primary sm" onclick="analyzeRaw()">Analyze API Result</button><button class="btn outline sm" onclick="loadClawDocs()">Claw402 Docs</button></div><div id="hint" class="hint"></div></div>
    <div class="card"><h3>3. Market Data</h3><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="inp"><label>Coin</label><select id="coin" onchange="syncSymbol()"><option>BTC</option><option>ETH</option><option>SOL</option><option>DOGE</option><option>XRP</option></select></div><div class="inp"><label>Symbol</label><input id="sym" value="BTCUSDT"></div><div class="inp"><label>Exchange</label><select id="ex"><option>binance</option><option>okx</option><option>bybit</option></select></div><div class="inp"><label>Interval</label><select id="interval"><option>1h</option><option>4h</option><option>12h</option><option>1d</option></select></div><div class="inp"><label>Size (bars)</label><input id="size" type="number" value="24" min="1" max="200"></div></div><div class="row"><button class="btn green" onclick="fetchLiq()">Fetch Liquidation</button><button class="btn outline sm" onclick="fetchMap()">Liq Map</button><button class="btn outline sm" onclick="toggleRaw()">Raw</button></div><div id="aerr" class="err"></div></div>
  </div>

  <div class="agent-grid">
    <div class="panel"><h4>Agent Strategy Config</h4><div class="cfg"><div class="inp"><label>Mode</label><select id="cfgMode"><option value="paper">paper</option><option value="live">live</option></select></div><div class="inp"><label>Min Liq USD</label><input id="cfgMinLiq" type="number" value="10000000"></div><div class="inp"><label>Dominance</label><input id="cfgDom" type="number" step="0.1" value="1.3"></div><div class="inp"><label>Entry</label><select id="cfgEntry"><option value="conservative">conservative</option><option value="fast">fast</option></select></div><div class="inp"><label>Notional USD</label><input id="cfgNotional" type="number" value="100"></div><div class="inp"><label>Max Notional</label><input id="cfgMaxNotional" type="number" value="1000"></div><div class="inp"><label>Leverage</label><input id="cfgLev" type="number" value="2"></div><div class="inp"><label>Max Leverage</label><input id="cfgMaxLev" type="number" value="5"></div><div class="inp"><label>Stop Loss %</label><input id="cfgSL" type="number" step="0.1" value="0.6"></div><div class="inp"><label>Take Profit %</label><input id="cfgTP" type="number" step="0.1" value="2.0"></div><div class="inp"><label>Stop Mode</label><select id="cfgStopMode"><option value="hybrid">hybrid</option><option value="heatmap">heatmap</option><option value="fixed">fixed</option></select></div><div class="inp"><label>Stop Buffer %</label><input id="cfgStopBuffer" type="number" step="0.1" value="0.2"></div><div class="inp"><label>Min R:R</label><input id="cfgRR" type="number" step="0.1" value="1.5"></div><div class="inp"><label>Max SL %</label><input id="cfgMaxSL" type="number" step="0.1" value="1.2"></div><div class="inp"><label>Max TP %</label><input id="cfgMaxTP" type="number" step="0.1" value="3.0"></div><div class="inp"><label>Heatmap Score</label><input id="cfgHeatScore" type="number" step="0.5" value="3.0"></div><div class="inp"><label>Heatmap Dist %</label><input id="cfgHeatDist" type="number" step="0.1" value="1.2"></div><div class="inp"><label>Leverage Tiers</label><select id="cfgHeatTiers"><option value="high,medium">high+medium</option><option value="high">high only</option><option value="high,medium,low">all</option></select></div><div class="inp"><label>LiqMap sec</label><input id="cfgLiqMapSec" type="number" value="600"></div><div class="inp"><label>API Budget</label><input id="cfgBudget" type="number" step="0.01" value="0.2"></div><div class="inp"><label>Trade HM Age</label><input id="cfgHeatTradeAge" type="number" value="300"></div><div class="inp"><label>Max Hold Min</label><input id="cfgMaxHold" type="number" value="30"></div><div class="inp"><label>Max Loss Streak</label><input id="cfgLossStreak" type="number" value="2"></div><div class="inp"><label>Pause Min</label><input id="cfgPauseMin" type="number" value="180"></div><div class="inp"><label>LLM Review</label><select id="cfgLlmReview"><option value="false">off</option><option value="true">on</option></select></div><div class="inp"><label>Review Key</label><input id="llmReviewKey" type="password" placeholder="optional"></div><div class="inp"><label>Review Model</label><input id="llmReviewModel" placeholder="default"></div><div class="inp"><label>Cooldown sec</label><input id="cfgCooldown" type="number" value="14400"></div><div class="inp"><label>Poll sec</label><input id="cfgPoll" type="number" value="60"></div></div><div class="row"><button class="btn primary" onclick="saveConfig()">Save Config</button><button class="btn green" onclick="agentTick(false)">Manual Tick</button><button class="btn outline" onclick="startAgent()">Start</button><button class="btn red" onclick="stopAgent()">Stop</button><button class="btn outline sm" onclick="agentTick(true)">Live Confirm Tick</button></div></div>
    <div class="panel"><h4>Latest Signal</h4><div id="sigBox"><div class="kv"><span>Action</span><b>-</b></div><div class="kv"><span>Confidence</span><b>-</b></div><div class="kv"><span>Reason</span><b>-</b></div></div></div>
    <div class="panel"><h4>Risk Decision</h4><div id="riskBox"><div class="kv"><span>Status</span><b>-</b></div><div class="kv"><span>SL / TP</span><b>-</b></div><div class="kv"><span>Reason</span><b>-</b></div></div><div id="heatBudget" style="margin-top:12px"><div class="kv"><span>LiqMap</span><b>-</b></div><div class="kv"><span>Cost</span><b>-</b></div><div class="kv"><span>Snapshot</span><b>-</b></div></div></div>
  </div>

  <div class="stats"><div class="st red"><div class="v" id="sl">$0</div><div class="l">1H Long Liq</div></div><div class="st green"><div class="v" id="ss">$0</div><div class="l">1H Short Liq</div></div><div class="st amber"><div class="v" id="sd">-</div><div class="l">Dominant</div></div><div class="st purple"><div class="v" id="sp">-</div><div class="l">Price</div></div></div>
  <div class="charts"><div class="panel"><h4>Liquidation Comparison</h4><div id="c1" class="echart"></div></div><div class="panel"><h4>Liquidation History</h4><div id="c2" class="echart"></div></div><div class="panel full"><div class="liq-page"><div class="liq-title"><span id="liqTitleExchange">Binance</span> <span id="liqTitleSymbol">BTCUSDT</span> 清算水平</div><div class="liq-card"><div class="liq-toolbar"><select id="liqPair"><option>Binance BTC/USDT 永续</option></select><select id="liqTf"><option>1分钟</option><option>5分钟</option><option>15分钟</option></select><label class="liq-check"><input type="checkbox" checked>高杠杆</label><label class="liq-check"><input type="checkbox">中杠杆</label><label class="liq-check"><input type="checkbox">低杠杆</label><label class="liq-slider">水平线 <input type="range" min="0" max="100" value="35"></label><label class="liq-slider">气泡 <input type="range" min="0" max="100" value="45"></label></div><div id="c3" class="liq-chart"></div></div></div></div><div class="panel"><h4>Long/Short Ratio</h4><div id="c4" class="echart"></div></div><div class="panel"><h4>Open Interest</h4><div id="c5" class="echart"></div></div></div>
  <div class="panel"><h4>Claw402 API Calls</h4><div class="row" id="apiCalls"></div><div class="hint">点击上方端点会调用 Claw402/CoinAnk，返回结果会写入 Raw，并可继续用 LLM 解读。</div></div>
  <div class="panel"><h4>LLM Natural Language Analysis</h4><div id="analysis" class="raw on">点击 Analyze API Result，会用你选择的 LLM Provider 把最近一次 API 返回整理成自然语言策略解读。</div></div>
  <div class="panel"><h4>Agent Chat</h4><div class="inp"><label>Ask the strategy agent</label><input id="agentQuestion" placeholder="例如：为什么这次不开单？止损为什么放这里？"></div><div class="row"><button class="btn primary sm" onclick="askAgent()">Ask Agent</button><button class="btn outline sm" onclick="askPreset('怎么看当前清算热力图？哪些区域对开单最关键？')">怎么看热力图</button><button class="btn outline sm" onclick="askPreset('现在如果要开单，agent 会调用哪些 API？预算和快照怎么控制？')">API/预算</button><button class="btn outline sm" onclick="askPreset('为什么当前信号不开单或被风控拒绝？')">为什么不开单</button></div><div id="agentAnswer" class="raw on">这里可以和清算反向策略 agent 对话。它会读取当前 signal、risk、heatmap、orders、API 地图和 AGENTS.md 后回答。</div></div>
  <div class="panel"><h4>Evolution Suggestions</h4><div class="row"><button class="btn primary sm" onclick="runEvolution()">Analyze Paper Results</button><button class="btn outline sm" onclick="applyEvolution()">Apply Selected</button></div><div id="evolutionBox" class="raw on">自我进化只生成建议，不会自动改 live、杠杆上限、最大仓位或 API 预算。至少 10 笔已关闭 paper 订单后更有意义。</div></div>
  <div class="panel"><h4>Orders</h4><table class="table"><thead><tr><th>Time</th><th>Mode</th><th>Symbol</th><th>Side</th><th>Qty</th><th>Entry</th><th>SL</th><th>TP</th><th>PnL</th><th>Status</th></tr></thead><tbody id="orders"><tr><td colspan="10">No orders</td></tr></tbody></table></div>
  <div id="raw" class="raw"></div>
</div>
<div id="mask" class="mask"><div class="spinner"></div></div>
<script src="/js/echarts.min.js"></script>
<script>
var P={{ providers|tojson }};var pk='',sel=null,lastApiData=null,lastEvolution=null;
document.addEventListener('DOMContentLoaded',function(){renderProviders();initCharts();loadConfig();refreshStatus();setInterval(refreshStatus,5000);});
function clearNode(el){while(el.firstChild)el.removeChild(el.firstChild);}
function textEl(tag,cls,text){var e=document.createElement(tag);if(cls)e.className=cls;e.textContent=text==null?'':String(text);return e;}
function renderProviders(){var g=document.getElementById('providers');clearNode(g);P.forEach(function(p){var card=document.createElement('div');card.className='prov';card.dataset.id=p.id;card.addEventListener('click',function(){pick(p.id);});var img=document.createElement('img');img.className='logo';img.src=p.logo;var fallback=textEl('div','fallback',(p.name||'LL').slice(0,2).toUpperCase());fallback.style.background=p.color||'#333';img.addEventListener('error',function(){img.style.display='none';fallback.style.display='flex';});card.appendChild(img);card.appendChild(fallback);card.appendChild(textEl('span','nm',p.name));g.appendChild(card);});pick('anthropic');}
function pick(id){sel=P.find(function(p){return p.id===id;});document.querySelectorAll('.prov').forEach(function(e){e.classList.remove('sel');});var e=document.querySelector('.prov[data-id="'+id+'"]');if(e)e.classList.add('sel');var m=document.getElementById('llmModel');clearNode(m);(sel&&sel.mdl&&sel.mdl.length?sel.mdl:['']).forEach(function(x){var opt=document.createElement('option');opt.textContent=x;opt.value=x;m.appendChild(opt);});var h=document.getElementById('hint');clearNode(h);if(sel){h.appendChild(textEl('span','ok','LLM: '+sel.name));h.appendChild(document.createTextNode(' — '+(sel.base||'custom endpoint')));}}
function show(e,v){if(typeof e=='string')e=document.getElementById(e);e.classList.toggle('on',v===undefined?!e.classList.contains('on'):!!v);}function toast(m,t){var e=document.createElement('div');e.className='toast '+(t||'ok');e.textContent=m;document.body.appendChild(e);setTimeout(function(){e.remove();},2500);}function setStatus(s){var m={stopped:['gry','Stopped'],load:['ylw','Loading'],paper:['grn','Paper Running'],live:['red','Live Armed'],ok:['grn','OK'],err:['red','Error']},x=m[s]||m.stopped,box=document.getElementById('status');clearNode(box);var dot=document.createElement('span');dot.className='dot '+x[0];box.appendChild(dot);box.appendChild(document.createTextNode(x[1]));}function mask(v){show('mask',v);}function fmt(n){n=+n||0;if(n>=1e9)return(n/1e9).toFixed(1)+'B';if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return n.toFixed(0);}function fmtM(n){n=+n||0;return n>=1000?n.toLocaleString('en-US',{maximumFractionDigits:2}):n>=1?n.toFixed(2):n.toFixed(4);}function syncSymbol(){document.getElementById('sym').value=document.getElementById('coin').value+'USDT';}
async function connect(){var key=document.getElementById('pk').value.trim();if(!key){toast('Enter key','err');return;}try{var r=await fetch('/api/wallet',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pk:key})});var d=await r.json();if(d.error){show('werr',true);document.getElementById('werr').textContent=d.error;return;}pk=key;document.getElementById('addr').textContent='Connected: '+d.address;show('addr',true);show('werr',false);toast('Wallet connected','ok');}catch(e){show('werr',true);document.getElementById('werr').textContent=e.message;}}
function marketPayload(){return{pk:document.getElementById('pk').value.trim(),coin:document.getElementById('coin').value,symbol:document.getElementById('sym').value,exchange:document.getElementById('ex').value,interval:document.getElementById('interval').value,size:document.getElementById('size').value};}
async function fetchLiq(){var p=marketPayload();if(!p.pk){toast('Enter wallet key','err');return;}setStatus('load');mask(true);show('aerr',false);try{var r=await fetch('/api/liquidation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});var d=await r.json();if(d.error){show('aerr',true);document.getElementById('aerr').textContent=d.error;setStatus('err');mask(false);return;}pk=p.pk;lastApiData=d;render(d);document.getElementById('raw').textContent=JSON.stringify(d,null,2);setStatus('ok');toast('Data loaded','ok');}catch(e){show('aerr',true);document.getElementById('aerr').textContent=e.message;setStatus('err');}mask(false);}
async function fetchMap(){var p=marketPayload();if(!p.pk){toast('Enter wallet key','err');return;}setStatus('load');mask(true);try{var r=await fetch('/api/liqmap',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pk:p.pk,coin:p.coin,interval:p.interval})});var d=await r.json();if(d.error){show('aerr',true);document.getElementById('aerr').textContent=d.error;setStatus('err');mask(false);return;}lastApiData=d;renderMap(d);document.getElementById('raw').textContent=JSON.stringify(d,null,2);setStatus('ok');toast('Map loaded','ok');}catch(e){show('aerr',true);document.getElementById('aerr').textContent=e.message;setStatus('err');}mask(false);}
async function loadHeatmapSnapshots(){try{var d=await (await fetch('/api/heatmap/snapshots')).json();if((d.snapshots||[]).length)renderMap({snapshots:d.snapshots,heatmap:d.heatmap.latest_snapshot&&d.heatmap.latest_snapshot.heatmap});}catch(e){}}
function readConfig(){return{mode:document.getElementById('cfgMode').value,coin:document.getElementById('coin').value,symbol:document.getElementById('sym').value,exchange:document.getElementById('ex').value,interval:document.getElementById('interval').value,size:+document.getElementById('size').value,min_liquidation_usd:+document.getElementById('cfgMinLiq').value,dominance_ratio:+document.getElementById('cfgDom').value,entry_mode:document.getElementById('cfgEntry').value,notional_usd:+document.getElementById('cfgNotional').value,max_notional_usd:+document.getElementById('cfgMaxNotional').value,leverage:+document.getElementById('cfgLev').value,max_leverage:+document.getElementById('cfgMaxLev').value,stop_loss_pct:+document.getElementById('cfgSL').value,take_profit_pct:+document.getElementById('cfgTP').value,stop_mode:document.getElementById('cfgStopMode').value,stop_buffer_pct:+document.getElementById('cfgStopBuffer').value,min_reward_risk:+document.getElementById('cfgRR').value,max_stop_loss_pct:+document.getElementById('cfgMaxSL').value,max_take_profit_pct:+document.getElementById('cfgMaxTP').value,min_heatmap_cluster_score:+document.getElementById('cfgHeatScore').value,max_heatmap_distance_pct:+document.getElementById('cfgHeatDist').value/100,allowed_heatmap_leverage_tiers:document.getElementById('cfgHeatTiers').value.split(','),liq_map_snapshot_interval_seconds:+document.getElementById('cfgLiqMapSec').value,daily_api_budget_usdc:+document.getElementById('cfgBudget').value,max_heatmap_trade_age_seconds:+document.getElementById('cfgHeatTradeAge').value,max_holding_minutes:+document.getElementById('cfgMaxHold').value,max_consecutive_losses:+document.getElementById('cfgLossStreak').value,loss_pause_minutes:+document.getElementById('cfgPauseMin').value,llm_review_enabled:document.getElementById('cfgLlmReview').value==='true',llm_review_provider:sel?sel.id:'anthropic',llm_review_model:document.getElementById('llmReviewModel').value,cooldown_seconds:+document.getElementById('cfgCooldown').value,poll_seconds:+document.getElementById('cfgPoll').value,live_enabled:document.getElementById('cfgMode').value==='live'};}
function applyConfig(c){if(!c)return;document.getElementById('cfgMode').value=c.mode||'paper';document.getElementById('cfgMinLiq').value=c.min_liquidation_usd;document.getElementById('cfgDom').value=c.dominance_ratio;document.getElementById('cfgEntry').value=c.entry_mode;document.getElementById('cfgNotional').value=c.notional_usd;document.getElementById('cfgMaxNotional').value=c.max_notional_usd;document.getElementById('cfgLev').value=c.leverage;document.getElementById('cfgMaxLev').value=c.max_leverage;document.getElementById('cfgSL').value=c.stop_loss_pct;document.getElementById('cfgTP').value=c.take_profit_pct;document.getElementById('cfgStopMode').value=c.stop_mode||'hybrid';document.getElementById('cfgStopBuffer').value=c.stop_buffer_pct||0.2;document.getElementById('cfgRR').value=c.min_reward_risk||1.5;document.getElementById('cfgMaxSL').value=c.max_stop_loss_pct||1.2;document.getElementById('cfgMaxTP').value=c.max_take_profit_pct||3;document.getElementById('cfgHeatScore').value=c.min_heatmap_cluster_score||3;document.getElementById('cfgHeatDist').value=((c.max_heatmap_distance_pct||0.012)*100).toFixed(2);document.getElementById('cfgHeatTiers').value=(c.allowed_heatmap_leverage_tiers||['high','medium']).join(',');document.getElementById('cfgLiqMapSec').value=c.liq_map_snapshot_interval_seconds||600;document.getElementById('cfgBudget').value=c.daily_api_budget_usdc||0.2;document.getElementById('cfgHeatTradeAge').value=c.max_heatmap_trade_age_seconds||300;document.getElementById('cfgMaxHold').value=c.max_holding_minutes||30;document.getElementById('cfgLossStreak').value=c.max_consecutive_losses||2;document.getElementById('cfgPauseMin').value=c.loss_pause_minutes||180;document.getElementById('cfgLlmReview').value=c.llm_review_enabled?'true':'false';document.getElementById('llmReviewModel').value=c.llm_review_model||'';document.getElementById('cfgCooldown').value=c.cooldown_seconds;document.getElementById('cfgPoll').value=c.poll_seconds;}
async function loadConfig(){var d=await (await fetch('/api/agent/config')).json();applyConfig(d.config);}async function saveConfig(){var d=await (await fetch('/api/agent/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(readConfig())})).json();if(d.error)toast(d.error,'err');else{applyConfig(d.config);toast('Config saved','ok');}}
async function agentTick(live){var key=document.getElementById('pk').value.trim();if(!key){toast('Enter wallet key','err');return;}await saveConfig();setStatus('load');mask(true);try{var d=await (await fetch('/api/agent/tick',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pk:key,live_confirmed:!!live,llm_review_api_key:document.getElementById('llmReviewKey').value.trim(),llm_review_provider:sel?sel.id:'anthropic',llm_review_model:document.getElementById('llmReviewModel').value})})).json();lastApiData=d;document.getElementById('raw').textContent=JSON.stringify(d,null,2);if(d.error){toast(d.error,'err');setStatus('err');}else{render(d.snapshot);if(d.snapshot&&d.snapshot.liq_map)renderMap({agg_map:d.snapshot.liq_map,heatmap:d.signal&&d.signal.metrics&&d.signal.metrics.heatmap});renderAgent(d);toast(d.order?'Order simulated':'Tick completed','ok');}}catch(e){toast(e.message,'err');setStatus('err');}mask(false);refreshStatus();}
async function startAgent(){var key=document.getElementById('pk').value.trim();if(!key){toast('Enter wallet key','err');return;}await saveConfig();var d=await (await fetch('/api/agent/start',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pk:key})})).json();if(d.error)toast(d.error,'err');else{toast('Agent started','ok');renderStatus(d);}}async function stopAgent(){var d=await (await fetch('/api/agent/stop',{method:'POST'})).json();renderStatus(d);toast('Agent stopped','ok');}
async function refreshStatus(){try{var d=await (await fetch('/api/agent/status')).json();renderStatus(d);}catch(e){}}
function renderStatus(d){if(!d)return;setStatus(d.running?(d.config&&d.config.mode==='live'?'live':'paper'):'stopped');renderAgent({signal:d.last_signal,risk:d.last_risk,order:d.last_order});renderHeatBudget(d);if(d.heatmap&&d.heatmap.snapshots_count>1)loadHeatmapSnapshots();loadOrders();}
function renderHeatBudget(d){var h=d.heatmap||{},cfg=d.config||{},box=document.getElementById('heatBudget');if(!box)return;clearNode(box);box.appendChild(kv('LiqMap',(h.liq_map_calls_today||0)+' calls'));box.appendChild(kv('Cost','$'+fmtM(h.liq_map_cost_today||0)+' / $'+fmtM(cfg.daily_api_budget_usdc||0)));box.appendChild(kv('Snapshot',h.latest_age_seconds==null?'-':Math.round(h.latest_age_seconds)+'s old'));box.appendChild(kv('Loss pause',d.loss_pause_remaining_seconds?Math.round(d.loss_pause_remaining_seconds)+'s':'-'));if(d.last_llm_review)box.appendChild(kv('LLM Review',d.last_llm_review.decision+' '+Math.round((d.last_llm_review.confidence||0)*100)+'%'));}
function kv(label,value,cls){var row=document.createElement('div');row.className='kv';row.appendChild(textEl('span','',label));row.appendChild(textEl('b',cls||'',value));return row;}
function renderAgent(d){if(d.signal){var s=d.signal,box=document.getElementById('sigBox'),hm=s.metrics&&s.metrics.heatmap,match=hm&&(s.side==='SHORT'?hm.short_match:hm.long_match),cl=match&&match.cluster;clearNode(box);box.appendChild(kv('Action',(s.action||'WAIT')+' '+(s.side||'NONE'),s.side==='LONG'?'ok':s.side==='SHORT'?'bad':'warn'));box.appendChild(kv('Confidence',Math.round((s.confidence||0)*100)+'%'));if(cl)box.appendChild(kv('Heatmap',cl.side+' '+cl.leverage_tier+' score '+cl.score+' dist '+(cl.distance_pct*100).toFixed(2)+'%'));box.appendChild(kv('Reason',(s.reasons||[]).join(' / ')||'-'));}if(d.risk){var r=d.risk,rbox=document.getElementById('riskBox');clearNode(rbox);rbox.appendChild(kv('Status',r.approved?'APPROVED':'REJECTED',r.approved?'ok':'bad'));rbox.appendChild(kv('SL / TP',fmtM(r.stop_loss)+' / '+fmtM(r.take_profit)));rbox.appendChild(kv('Reason',(r.reasons||[]).join(' / ')||'-'));}}
async function loadOrders(){var d=await (await fetch('/api/orders')).json();var body=document.getElementById('orders');clearNode(body);var orders=(d.orders||[]).slice(0,20);if(!orders.length){var empty=document.createElement('tr'),td=document.createElement('td');td.colSpan=10;td.textContent='No orders';empty.appendChild(td);body.appendChild(empty);return;}orders.forEach(function(o){var tr=document.createElement('tr');[String(o.timestamp||'').slice(11,19),o.mode,o.symbol,o.side,o.qty,fmtM(o.entry_price),fmtM(o.stop_loss),fmtM(o.take_profit),fmtM(o.pnl_usd),o.status].forEach(function(v){tr.appendChild(textEl('td','',v));});body.appendChild(tr);});}
async function analyzeRaw(){if(!lastApiData){toast('Call an API first','err');return;}if(!sel){toast('Pick LLM provider','err');return;}var key=document.getElementById('llmKey').value.trim();if(!key){toast('Enter LLM API key','err');return;}document.getElementById('analysis').textContent='Analyzing...';try{var d=await (await fetch('/api/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({provider:sel.id,api_key:key,model:document.getElementById('llmModel').value,data:lastApiData,prompt:'重点判断是否适合大额清算反向开单，并解释参数。'})})).json();if(d.error){document.getElementById('analysis').textContent=d.error;toast(d.error,'err');}else{document.getElementById('analysis').textContent=d.analysis||'-';toast('Analysis ready','ok');}}catch(e){document.getElementById('analysis').textContent=e.message;toast(e.message,'err');}}
function askPreset(q){document.getElementById('agentQuestion').value=q;askAgent();}
async function askAgent(){if(!sel){toast('Pick LLM provider','err');return;}var key=document.getElementById('llmKey').value.trim();if(!key){toast('Enter LLM API key','err');return;}var q=document.getElementById('agentQuestion').value.trim();if(!q){toast('Enter question','err');return;}var box=document.getElementById('agentAnswer');box.textContent='Thinking...';try{var d=await (await fetch('/api/agent/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({provider:sel.id,api_key:key,model:document.getElementById('llmModel').value,question:q})})).json();if(d.error){box.textContent=d.error;toast(d.error,'err');}else{box.textContent=d.answer||'-';toast('Agent answered','ok');}}catch(e){box.textContent=e.message;toast(e.message,'err');}}
async function loadClawDocs(){var d=await (await fetch('/api/claw402/docs')).json();lastApiData=d;document.getElementById('raw').textContent=JSON.stringify(d,null,2);document.getElementById('analysis').textContent=(d.endpoints||[]).map(function(x,i){return (i+1)+'. '+x.name+' '+x.method+' '+x.path+'：'+x.natural+' 参数：'+(x.params||[]).join(', ');}).join('\n');var calls=document.getElementById('apiCalls');clearNode(calls);(d.endpoints||[]).forEach(function(x){var b=textEl('button','btn outline sm',x.name);b.addEventListener('click',function(){callClawEndpoint(x.name);});calls.appendChild(b);});toast('Claw402 docs loaded','ok');}
async function runEvolution(){var box=document.getElementById('evolutionBox');box.textContent='Analyzing paper results...';try{var d=await (await fetch('/api/agent/evolve',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({lookback:50})})).json();lastEvolution=d.evolution;box.textContent=JSON.stringify(d.evolution,null,2);toast('Evolution ready','ok');}catch(e){box.textContent=e.message;toast(e.message,'err');}}
async function applyEvolution(){if(!lastEvolution){toast('Run evolution first','err');return;}var recs=(lastEvolution.recommendations||[]).filter(function(r){return r.param&&r.param!=='none';});if(!recs.length){toast('No applicable recommendations','err');return;}try{var d=await (await fetch('/api/agent/evolve/apply',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({recommendations:recs,selected:recs.map(function(r){return r.param;})})})).json();document.getElementById('evolutionBox').textContent=JSON.stringify(d,null,2);if(d.config)applyConfig(d.config);toast('Selected suggestions applied','ok');}catch(e){toast(e.message,'err');}}
async function callClawEndpoint(name){var p=marketPayload();if(!p.pk){toast('Enter wallet key','err');return;}if(name==='Latest price'){await fetchLiq();return;}if(name==='Liquidation intervals'||name==='Aggregated liquidation history'||name==='Open interest'||name==='Long/short realtime'||name==='Current funding'){await fetchLiq();return;}if(name==='Aggregated liquidation map'){await fetchMap();return;}toast('This endpoint is documented; dedicated UI call is not wired yet','err');}
function initCharts(){['c1','c2','c3','c4','c5'].forEach(function(id){var c=echarts.init(document.getElementById(id));c.setOption({title:{text:'Waiting...',left:'center',top:'center',textStyle:{color:'#444',fontSize:12}}});});}
window.addEventListener('resize',function(){if(typeof echarts==='undefined')return;try{['c1','c2','c3','c4','c5'].forEach(function(id){var d=document.getElementById(id);var c=echarts.getInstanceByDom(d);if(c)c.resize();});}catch(e){}});
function render(d){var itv=d.intervals||{};var lv=+itv.h1Long||0,sv=+itv.h1Short||0;document.getElementById('sl').textContent='$'+fmt(lv);document.getElementById('ss').textContent='$'+fmt(sv);document.getElementById('sd').textContent=lv>sv?'Long':sv>lv?'Short':'-';document.getElementById('sp').textContent=d.price?'$'+fmtM(d.price):'-';bar('c1',['1H','24H'],[{n:'Long',d:[itv.h1Long||0,itv.h24Long||0],c:'#e44'},{n:'Short',d:[itv.h1Short||0,itv.h24Short||0],c:'#0c6'}]);var h=d.history||[];line('c2',h.map(function(x){return x.time||'';}),[{n:'Long',d:h.map(function(x){return x.longVolUsd||x.longTurnover||0;}),c:'#e44'},{n:'Short',d:h.map(function(x){return x.shortVolUsd||x.shortTurnover||0;}),c:'#0c6'}]);var ls=d.long_short||[];barV('c4',ls.map(function(x){return x.exchangeName||x.exchange||'';}).slice(0,12),{n:'L/S Ratio',d:ls.map(function(x){return x.longShortRatio||0;}).slice(0,12),fc:function(v){return v>1?'#e44':'#0c6';}});var oi=d.oi||[];barV('c5',oi.map(function(x){return x.exchangeName||x.exchange||'';}).slice(0,12),{n:'OI',d:oi.map(function(x){return x.openInterest||x.coinValue||0;}).slice(0,12),c:'#63f'});}
function renderMap(d){var c=echarts.getInstanceByDom(document.getElementById('c3'))||echarts.init(document.getElementById('c3')),hm=d.heatmap||{};var frames=(d.snapshots||[]).slice().reverse(),map=d.agg_map||{},lastPrice=0,profile={},maxVol=0,rows=[],priceLine=[],bubbles=[];if(frames.length){lastPrice=+(frames[frames.length-1].price||0);frames.forEach(function(frame,idx){var m=frame.liq_map||{},prices=(m.prices||[]).map(Number),ex=[];for(var k in m){if(['prices','price','lastIndex','last_index','lastPrice','last_price'].indexOf(k)>=0)continue;if(Array.isArray(m[k])&&m[k].length===prices.length)ex.push(k);}for(var i=0;i<prices.length;i++){var p=prices[i],total=0;for(var ei=0;ei<ex.length;ei++)total+= +(m[ex[ei]][i]||0);if(total<=0)continue;profile[p]=(profile[p]||0)+total;if(total>maxVol)maxVol=total;rows.push([idx,p,total,p>=lastPrice?'above':'below']);}priceLine.push([idx,+(frame.price||lastPrice)]);});}else{var prices=(map.prices||[]).map(Number),exchanges=[];lastPrice=+(map.lastPrice||map.last_price||document.getElementById('sp').textContent.replace(/[$,]/g,'')||0);for(var k2 in map){if(['prices','price','lastIndex','last_index','lastPrice','last_price'].indexOf(k2)>=0)continue;if(Array.isArray(map[k2])&&map[k2].length===prices.length)exchanges.push(k2);}if(!exchanges.length||!prices.length){c.setOption({title:{text:'No heatmap data',left:'center',top:'center',textStyle:{color:'#444'}}});return;}for(var i2=0;i2<prices.length;i2++){var price=prices[i2],total2=0;for(var ei2=0;ei2<exchanges.length;ei2++)total2+= +(map[exchanges[ei2]][i2]||0);if(total2<=0)continue;profile[price]=(profile[price]||0)+total2;if(total2>maxVol)maxVol=total2;}var ks=Object.keys(profile).map(Number).sort(function(a,b){return a-b;}),cols=96;ks.forEach(function(p){var norm=profile[p]/maxVol;for(var t=0;t<cols;t++){var wave=.55+.45*Math.sin((t/cols)*Math.PI*1.8+p/260),fade=.25+.75*Math.pow((t+1)/cols,.75),turn=profile[p]*wave*fade;if(turn/maxVol>.14)rows.push([t,p,turn,p>=lastPrice?'above':'below']);}});for(var t2=0;t2<cols;t2++)priceLine.push([t2,lastPrice+(t2/cols-.55)*lastPrice*.035+Math.sin(t2*.35)*lastPrice*.0007]);}var keys=Object.keys(profile).map(Number).sort(function(a,b){return a-b;});if(!keys.length)return;document.getElementById('liqTitleExchange').textContent=(document.getElementById('ex').value||'Binance').replace(/^./,function(s){return s.toUpperCase();});document.getElementById('liqTitleSymbol').textContent=document.getElementById('sym').value||'BTCUSDT';var minP=Math.min.apply(null,keys.concat([lastPrice])),maxP=Math.max.apply(null,keys.concat([lastPrice])),pad=(maxP-minP)*0.08||lastPrice*0.01;minP-=pad;maxP+=pad;var xMax=Math.max(96,priceLine.length?priceLine[priceLine.length-1][0]+1:96),profileData=keys.map(function(p){return[profile[p],p,p>=lastPrice?'above':'below'];});(hm.clusters||[]).slice(0,12).forEach(function(cl){bubbles.push({value:[Math.max(4,Math.min(xMax-8,Math.round(xMax*(.18+Math.min(cl.distance_pct||0,.03)*12)))),cl.center],symbolSize:Math.max(22,Math.min(72,cl.score*3)),itemStyle:{color:'transparent',borderColor:cl.side==='above'?'#00d6d6':'#ff6a2a',borderWidth:2}});});var mark={silent:true,symbol:'none',label:{formatter:'Current $'+fmtM(lastPrice),color:'#fff',backgroundColor:'#00c47a',padding:[4,6],borderRadius:2,position:'end'},lineStyle:{color:'#20c997',width:1,type:'dashed'},data:[{yAxis:lastPrice}]};c.setOption({backgroundColor:'#fff',animation:false,tooltip:{trigger:'item',backgroundColor:'#fff',borderColor:'#ddd',textStyle:{color:'#222'}},grid:[{left:0,right:210,top:0,bottom:26},{right:34,width:145,top:0,bottom:26}],xAxis:[{type:'value',min:0,max:xMax,axisLabel:{color:'#222',formatter:function(v){return v%24===0?('T+'+v):'';}},axisLine:{lineStyle:{color:'#ddd'}},splitLine:{show:false}},{type:'value',gridIndex:1,axisLabel:{show:false},axisLine:{show:false},splitLine:{show:false}}],yAxis:[{type:'value',min:minP,max:maxP,position:'right',axisLabel:{color:'#222',formatter:function(v){return fmtM(v);}},axisLine:{lineStyle:{color:'#ddd'}},splitLine:{lineStyle:{color:'#eee'}}},{type:'value',gridIndex:1,min:minP,max:maxP,axisLabel:{show:false},axisLine:{show:false},splitLine:{show:false}}],visualMap:[{show:false,min:0,max:maxVol,seriesIndex:0,inRange:{color:['rgba(235,240,240,.18)','rgba(0,220,210,.42)','rgba(0,205,195,.9)','rgba(20,40,42,1)']}},{show:false,min:0,max:maxVol,seriesIndex:1,inRange:{color:['rgba(245,220,220,.22)','rgba(255,60,45,.55)','rgba(255,0,0,.92)','rgba(255,225,0,1)']}}],series:[{name:'High leverage above',type:'heatmap',data:rows.filter(function(r){return r[3]==='above';}),xAxisIndex:0,yAxisIndex:0,pointSize:7,blurSize:10,markLine:mark},{name:'High leverage below',type:'heatmap',data:rows.filter(function(r){return r[3]==='below';}),xAxisIndex:0,yAxisIndex:0,pointSize:7,blurSize:10,markLine:mark},{name:'Price',type:'line',data:priceLine,xAxisIndex:0,yAxisIndex:0,symbol:'none',smooth:true,lineStyle:{color:'rgba(230,120,120,.7)',width:1},z:4},{name:'Cluster',type:'scatter',data:bubbles,xAxisIndex:0,yAxisIndex:0,z:6},{name:'Profile',type:'bar',data:profileData,xAxisIndex:1,yAxisIndex:1,barWidth:2,itemStyle:{color:function(p){return p.data[2]==='above'?'rgba(0,120,120,.42)':'rgba(210,0,0,.42)';}}}]});}
function bar(id,x,s){var c=echarts.getInstanceByDom(document.getElementById(id))||echarts.init(document.getElementById(id));c.setOption({tooltip:{trigger:'axis',backgroundColor:'#111',borderColor:'#333'},grid:{left:60,right:10,top:20,bottom:30},xAxis:{type:'category',data:x,axisLabel:{color:'#888'}},yAxis:{type:'value',axisLabel:{color:'#888',formatter:function(v){return '$'+fmt(v);}}},series:s.map(function(s){return{name:s.n,type:'bar',data:s.d,itemStyle:{color:s.c}};})});}
function line(id,x,s){var c=echarts.getInstanceByDom(document.getElementById(id))||echarts.init(document.getElementById(id));c.setOption({tooltip:{trigger:'axis',backgroundColor:'#111',borderColor:'#333'},grid:{left:60,right:10,top:30,bottom:30},legend:{data:s.map(function(s){return s.n;}),textStyle:{color:'#888'},top:0},xAxis:{type:'category',data:x,axisLabel:{color:'#888',rotate:45,fontSize:9}},yAxis:{type:'value',axisLabel:{color:'#888',formatter:function(v){return '$'+fmt(v);}}},series:s.map(function(s){return{name:s.n,type:'line',smooth:true,data:s.d,lineStyle:{color:s.c,width:2},itemStyle:{color:s.c},symbol:'none'};})});}
function barV(id,x,s){if(typeof echarts==='undefined')return;if(!Array.isArray(s))s=[s];var c=echarts.getInstanceByDom(document.getElementById(id))||echarts.init(document.getElementById(id));c.setOption({tooltip:{trigger:'axis',backgroundColor:'#111',borderColor:'#333'},grid:{left:80,right:10,top:20,bottom:50},xAxis:{type:'category',data:x,axisLabel:{color:'#888',rotate:30,fontSize:9}},yAxis:{type:'value',axisLabel:{color:'#888'}},series:s.map(function(s){return{name:s.n,type:'bar',data:s.d,itemStyle:s.fc?{color:function(p){return s.fc(p.value);}}:{color:s.c}};})});}
function toggleRaw(){show('raw');}
</script>
</body>
</html>
